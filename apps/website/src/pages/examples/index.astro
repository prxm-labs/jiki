---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import CategoryFilter from "../../components/CategoryFilter.tsx";
import { examples } from "../../data/examples";

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://jiki.sh/",
    },
    { "@type": "ListItem", position: 2, name: "Examples" },
  ],
};

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "jiki Examples",
  description: `Browse ${examples.length} examples showing jiki in action, from React and Vue to Express, Jest, and Plugins.`,
  url: "https://jiki.sh/examples/",
};
---

<MarketingLayout
  title="Examples | jiki"
  description={`Browse ${examples.length} examples showing jiki in action, from React and Vue to Express, Jest, and Plugins.`}
  jsonLd={[breadcrumbLd, collectionLd]}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <div class="mb-12">
      <SectionHeading label="Examples" as="h1" size="large">
        <em>The browser goes vroom</em>
      </SectionHeading>
      <p class="mt-4 max-w-2xl text-lg text-zinc-400">
        {examples.length} examples covering frameworks, servers, and testing tools,
        all running in the browser.
      </p>
    </div>

    <CategoryFilter client:visible examples={examples} />
  </section>
</MarketingLayout>
