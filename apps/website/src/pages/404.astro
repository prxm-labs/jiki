---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="404 - Page Not Found | jiki">
  <section class="mx-auto flex max-w-2xl flex-col items-center justify-center px-4 py-32 text-center sm:px-6 lg:px-8">
    <div class="mb-4 font-mono text-6xl font-bold text-zinc-800">404</div>
    <h1 class="font-display text-3xl text-zinc-100 sm:text-4xl">
      <em>Page not found</em>
    </h1>
    <p class="mt-4 text-lg text-zinc-400">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="mt-8 flex gap-4">
      <a
        href="/"
        data-astro-prefetch="load"
        class="inline-flex items-center rounded-md bg-accent px-6 py-2.5 font-mono text-sm font-medium tracking-wider text-zinc-950 transition-colors hover:bg-accent-light"
      >
        Go Home
      </a>
      <a
        href="/docs/getting-started/introduction"
        data-astro-prefetch="hover"
        class="inline-flex items-center rounded-md border border-zinc-700 px-6 py-2.5 font-mono text-sm tracking-wider text-zinc-300 transition-colors hover:border-zinc-500 hover:text-zinc-100"
      >
        Read Docs
      </a>
    </div>
  </section>
</MarketingLayout>
