---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getCollection } from "astro:content";

const items = await getCollection("roadmap");

const statusOrder = ["in-progress", "planned", "done"] as const;

const grouped = statusOrder.map((status) => ({
  status,
  items: items
    .filter((item) => item.data.status === status)
    .sort((a, b) => a.data.order - b.data.order),
}));

const statusConfig = {
  "in-progress": { label: "In Progress", dot: "bg-amber-500" },
  planned: { label: "Planned", dot: "bg-blue-500" },
  done: { label: "Done", dot: "bg-emerald-500" },
} as const;

const priorityConfig = {
  high: "bg-red-500/10 text-red-400",
  medium: "bg-amber-500/10 text-amber-400",
  low: "bg-blue-500/10 text-blue-400",
} as const;
---

<MarketingLayout
  title="Roadmap | jiki"
  description="See what we're building, what's in progress, and what's shipped in jiki."
>
  <section class="relative overflow-hidden">
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent/5 via-transparent to-transparent"
    >
    </div>
    <div
      class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-24 lg:px-8"
    >
      <SectionHeading label="Roadmap" as="h1" size="large">
        <em>What we're</em> building
      </SectionHeading>
      <p class="mx-auto mt-4 max-w-lg text-lg text-zinc-400">
        A look at what's in progress, what's planned next, and what's already
        shipped.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-20 sm:px-6 lg:px-8">
    {
      grouped.map(
        ({ status, items }) =>
          items.length > 0 && (
            <div class="mb-12 last:mb-0">
              <div class="mb-4 flex items-center gap-2.5">
                <span
                  class:list={[
                    "h-2 w-2 rounded-full",
                    statusConfig[status].dot,
                  ]}
                />
                <h2 class="font-mono text-[11px] uppercase tracking-widest text-zinc-400">
                  {statusConfig[status].label}
                </h2>
              </div>
              <div class="space-y-2">
                {items.map((item) => (
                  <div class="flex items-start justify-between gap-4 rounded-lg border border-zinc-800/50 bg-zinc-900/50 px-5 py-4">
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-zinc-100">
                        {item.data.title}
                      </div>
                      <div class="mt-1 text-sm text-zinc-500">
                        {item.data.description}
                      </div>
                    </div>
                    <span
                      class:list={[
                        "shrink-0 rounded px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider",
                        priorityConfig[item.data.priority],
                      ]}
                    >
                      {item.data.priority}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ),
      )
    }
  </section>
</MarketingLayout>
