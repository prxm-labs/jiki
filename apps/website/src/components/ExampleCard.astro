---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
}

const { title, description, slug, category } = Astro.props;
---

<a
  href={`/examples/${slug}`}
  data-astro-prefetch="viewport"
  class="card-interactive group flex flex-col rounded-lg border border-zinc-800 bg-zinc-900/50 p-5 hover:border-accent/40"
>
  <div class="mb-2 font-mono text-[10px] uppercase tracking-widest text-zinc-500">{category}</div>
  <h3 class="mb-1 font-display text-base italic text-zinc-100 group-hover:text-accent transition-colors">{title}</h3>
  <p class="text-sm leading-[1.75] text-zinc-400">{description}</p>
</a>
