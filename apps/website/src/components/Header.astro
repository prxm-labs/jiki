---
import Logo from "./Logo.astro";
import { headerNav } from "../data/navigation";

const currentPath = Astro.url.pathname;
---

<header
  transition:persist
  transition:animate="none"
  class="sticky top-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-lg">
  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a
      href="/"
      class="flex items-center gap-2 font-mono text-lg font-bold tracking-tight text-zinc-100">
      <Logo class="w-6 h-auto" />
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {
        headerNav.map(item => {
          const isActive = currentPath.startsWith(
            item.href.split("/").slice(0, 2).join("/"),
          );
          return (
            <a
              href={item.href}
              data-header-link
              data-astro-prefetch="load"
              class:list={[
                "relative px-3 py-2 font-mono text-xs tracking-widest transition-colors",
                isActive ? "text-accent" : "text-zinc-400 hover:text-zinc-100",
              ]}>
              {item.label}
              {isActive && (
                <span
                  data-header-underline
                  class="absolute inset-x-3 -bottom-[calc(0.5rem+1px)] h-px bg-accent"
                />
              )}
            </a>
          );
        })
      }
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="px-3 py-2 font-mono text-xs tracking-widest text-zinc-400 transition-colors hover:text-zinc-100">
        GITHUB
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/docs/getting-started/introduction"
        class="hidden rounded-md bg-accent px-4 py-1.5 font-mono text-xs font-medium tracking-wider text-zinc-950 transition-colors hover:bg-accent-light sm:inline-flex">
        GET STARTED
      </a>
      <button
        id="mobile-menu-btn"
        class="inline-flex items-center justify-center rounded-md p-2 text-zinc-400 hover:text-zinc-100 md:hidden"
        aria-label="Open menu"
        aria-expanded="false">
        <svg
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu (CSS transition via .mobile-menu) -->
  <div
    id="mobile-menu"
    class="mobile-menu border-t border-zinc-800/50 md:hidden">
    <div class="mobile-menu-inner">
      <div class="space-y-1 px-4 py-3">
        {
          headerNav.map(item => (
            <a
              href={item.href}
              class="block py-2 font-mono text-sm tracking-widest text-zinc-400 hover:text-zinc-100">
              {item.label}
            </a>
          ))
        }
        <a
          href="https://github.com/prxm-labs/jiki"
          target="_blank"
          rel="noopener noreferrer"
          class="block py-2 font-mono text-sm tracking-widest text-zinc-400 hover:text-zinc-100">
          GITHUB
        </a>
        <a
          href="/docs/getting-started/introduction"
          class="mt-2 block rounded-md bg-accent px-4 py-2 text-center font-mono text-sm font-medium tracking-wider text-zinc-950">
          GET STARTED
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    if (!btn || btn.dataset.menuInit) return;
    btn.dataset.menuInit = "true";
    const menu = document.getElementById("mobile-menu");
    btn.addEventListener("click", () => {
      const isOpen = menu?.classList.toggle("is-open");
      btn.setAttribute("aria-expanded", String(!!isOpen));
    });
  }

  const ACTIVE_CLASS = "text-accent";
  const INACTIVE_CLASSES = "text-zinc-400 hover:text-zinc-100";
  const UNDERLINE_CLASSES =
    "absolute inset-x-3 -bottom-[calc(0.5rem+1px)] h-px bg-accent";

  function updateHeaderActive() {
    const path = window.location.pathname;
    document
      .querySelectorAll<HTMLAnchorElement>("[data-header-link]")
      .forEach(a => {
        const href = a.getAttribute("href") ?? "";
        const prefix = href.split("/").slice(0, 2).join("/");
        const isActive = path.startsWith(prefix);

        a.classList.remove(ACTIVE_CLASS);
        INACTIVE_CLASSES.split(" ").forEach(c => a.classList.remove(c));

        if (isActive) {
          a.classList.add(ACTIVE_CLASS);
          if (!a.querySelector("[data-header-underline]")) {
            const span = document.createElement("span");
            span.dataset.headerUnderline = "";
            span.className = UNDERLINE_CLASSES;
            a.appendChild(span);
          }
        } else {
          INACTIVE_CLASSES.split(" ").forEach(c => a.classList.add(c));
          a.querySelector("[data-header-underline]")?.remove();
        }
      });
  }

  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
  document.addEventListener("astro:after-swap", updateHeaderActive);
</script>
