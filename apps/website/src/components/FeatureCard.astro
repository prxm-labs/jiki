---
interface Props {
  number: string;
  label: string;
  title: string;
  description: string;
}

const { number, label, title, description } = Astro.props;
---

<div class="card-interactive group rounded-lg border border-zinc-800 bg-zinc-900/50 p-6 hover:border-accent/40">
  <div class="mb-3 font-mono text-xs tracking-widest text-accent/70">
    {number} <span class="text-zinc-500">{label}</span>
  </div>
  <h3 class="mb-2 font-display text-lg italic text-zinc-100">{title}</h3>
  <p class="text-sm leading-[1.75] text-zinc-400">{description}</p>
</div>
