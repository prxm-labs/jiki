---
interface Props {
  label?: string;
  as?: "h1" | "h2";
  size?: "base" | "large";
}

const { label, as: Tag = "h2", size = "base" } = Astro.props;
const headingClass =
  size === "large"
    ? "font-display text-4xl text-zinc-100 sm:text-5xl"
    : "font-display text-3xl text-zinc-100 sm:text-4xl";
---

{label && (
  <div class="mb-3 font-mono text-xs uppercase tracking-widest text-accent">
    {label}
  </div>
)}
<Tag class={headingClass}>
  <slot />
</Tag>
