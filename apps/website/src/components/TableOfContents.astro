---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <aside class="hidden w-48 shrink-0 xl:block">
    <nav class="sticky top-20 max-h-[calc(100vh-5rem)] overflow-y-auto pb-8 pl-4">
      <h4 class="mb-3 font-mono text-xs uppercase tracking-widest text-zinc-500">
        On this page
      </h4>
      <ul class="space-y-1.5">
        {filteredHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block text-sm transition-colors hover:text-zinc-100',
                heading.depth === 3 ? 'pl-3 text-zinc-500' : 'text-zinc-400',
              ]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}
