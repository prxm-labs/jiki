{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "in-progress",
        "done"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "order": {
      "type": "number"
    },
    "touchedAreas": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internalNotes": {
      "default": "",
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "status",
    "priority",
    "order"
  ]
}