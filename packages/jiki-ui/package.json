{
  "name": "jiki-ui",
  "version": "0.1.0",
  "description": "Shared React UI components for jiki examples — CodeEditor and Terminal.",
  "type": "module",
  "license": "MIT",
  "bugs": "https://github.com/prxm-labs/jiki/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prxm-labs/jiki.git",
    "directory": "packages/jiki-ui"
  },
  "homepage": "https://jiki.sh",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "shiki": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json",
    "format": "prettier --write .",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  }
}
